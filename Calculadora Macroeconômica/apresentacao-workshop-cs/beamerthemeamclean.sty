% AGENDA / PROGRESSO (slide escuro do Template: lista de seções,
% a corrente em branco, as demais em slate atenuado)
% \amagenda{2}{Contexto, Proposta comercial, Cronograma, Investimento}
\NewDocumentCommand{\amagenda}{m m}{%
  \begin{frame}[plain, noframenumbering]
    \begin{tikzpicture}[remember picture, overlay]
      \fill[amNavy] (current page.north west) rectangle (current page.south east);
      \draw[amSlateLight, line width=0.5pt]
        (current page.north west) ++(0,-4.72mm) -- ++(\paperwidth,0);
      \node[anchor=east, inner sep=0] at ($(current page.north east)+(-3.2mm,-2.4mm)$)
        {\includegraphics[width=14.3mm]{\am@assets/logos/am-wordmark-white.png}};
      \edef\am@agcur{#1}%
      \foreach \am@item [count=\am@i] in {#2} {\global\let\am@nag=\am@i}
      \pgfmathsetmacro{\am@agystart}{45 - \am@nag*4.5}%
      \draw[amSlate!45, line width=0.3pt]
        ($(current page.north west)+(33mm,-\am@agystart mm+2mm)$) -- ++(95mm,0);
      \foreach \am@item [count=\am@i] in {#2} {
        \ifnum\am@i=\am@agcur\relax
          \def\am@agtxt{\fontsize{11}{13}\selectfont\color{white}}%
          \def\am@aglc{white}%
        \else
          \def\am@agtxt{\amlightfont\fontsize{11}{13}\selectfont\color{amSlate!75}}%
          \def\am@aglc{amSlate!45}%
        \fi
        \node[anchor=north west, inner sep=0]
          at ($(current page.north west)+(33mm,{-\am@agystart mm-(\am@i-1)*9mm-3mm})$)
          {\am@agtxt\am@item};
        \draw[\am@aglc, line width=0.3pt]
          ($(current page.north west)+(33mm,{-\am@agystart mm-\am@i*9mm+1mm})$) -- ++(95mm,0);
      }
    \end{tikzpicture}%
  \end{frame}
}

% FAIXA DE STATS (decks institucionais: números grandes lado a lado
% com separadores verticais)
% \amstatstrip{+40/anos de atuação, 46/países, +1.1k/profissionais}
\newcommand{\amstatstrip}[1]{%
  \begin{center}
  \begin{tikzpicture}
    \foreach \am@num/\am@lbl [count=\am@i] in {#1} {\global\let\am@ns=\am@i}
    \pgfmathsetmacro{\am@sw}{(\textwidth-8mm)/\am@ns}%
    \foreach \am@num/\am@lbl [count=\am@i from 0] in {#1} {
      \node[anchor=north, inner sep=0, text width=\am@sw pt, align=center]
        at ({(\am@i+0.5)*\am@sw pt},0)
        {\amcondfont\bfseries\fontsize{16}{17}\selectfont\color{amSignal}\am@num};
      \node[anchor=north, inner sep=0, text width={\am@sw pt - 6mm}, align=center]
        at ({(\am@i+0.5)*\am@sw pt},-7.5mm)
        {\amcondlightnhfont\fontsize{5.6}{7}\selectfont
         \color{\ifamdark amMist\else amGray\fi}\am@lbl};
      \ifnum\am@i>0
        \draw[\ifamdark amSlate!50\else amMist\fi, line width=0.4pt]
          ({\am@i*\am@sw pt},-1mm) -- ({\am@i*\am@sw pt},-12mm);
      \fi
    }
  \end{tikzpicture}
  \end{center}
}

% BLOCO DE KPI (painel de resultados dos cartões de credenciais)
% \amkpi{US\$ 4,5 BI}{capex otimizado no programa}
\newcommand{\amkpi}[2]{%
  \begin{tcolorbox}[sharp corners, boxrule=0pt, colback=amSlate!15,
    left=2.4mm, right=2.4mm, top=2mm, bottom=2mm, boxsep=0pt]
    {\amcondfont\bfseries\fontsize{13}{14}\selectfont\color{amNavy}#1\par}
    {\vspace*{0.4mm}\amcondlightfont\fontsize{5.6}{7}\selectfont\color{amGray}#2\par}
  \end{tcolorbox}}

% BIO (cartão de pessoa do Institutional_Bios: foto circular com anel
% slate, nome navy, cargo slate, texto cinza)
% \ambio{img/foto.jpg}{Nome Sobrenome}{Managing Director}{São Paulo, Brasil}{Bio em 2 a 4 frases.}
% Foto vazia ({}) desenha o placeholder cinza.
\newcommand{\ambio}[5]{%
  \begin{minipage}[t]{\linewidth}
    \begin{tikzpicture}
      \ifstrempty{#1}{%
        \fill[amMist] (0,0) circle (7.5mm);
      }{%
        \begin{scope}\clip (0,0) circle (7.5mm);
          \node[inner sep=0] at (0,0) {\includegraphics[width=15.5mm]{#1}};
        \end{scope}%
      }%
      \draw[amSlate, line width=0.4pt] (0,0) circle (7.9mm);
    \end{tikzpicture}\par\vspace{1.6mm}
    {\bfseries\fontsize{8}{9.5}\selectfont\color{amNavy}#2\par}
    {\vspace*{0.5mm}\amcondlightfont\fontsize{5.6}{7}\selectfont\color{amSlate}#3\\#4\par}
    \vspace{1.6mm}
    {\amcondlightfont\fontsize{5.6}{7.4}\selectfont\color{\ifamdark amMist\else amGray\fi}#5\par}
  \end{minipage}}

% GANTT (componente oficial: barras slate com pontos nas extremidades,
% colunas de meses com linhas tracejadas)
% \amgantt{Jan, Fev, Mar, Abr, Mai, Jun}{Diagnóstico/1/2, Desenho/2/4, Implementação/4/6}
\newcommand{\amgantt}[2]{%
  \begin{center}
  \begin{tikzpicture}
    \foreach \am@m [count=\am@i] in {#1} {\global\let\am@ngm=\am@i}
    \foreach \am@r/\am@a/\am@b [count=\am@j] in {#2} {\global\let\am@ngr=\am@j}
    \def\am@glw{30mm}%
    \pgfmathsetmacro{\am@gcw}{(\textwidth-\am@glw-4mm)/\am@ngm}%
    \pgfmathsetmacro{\am@gh}{\am@ngr*8}%
    \pgfmathsetmacro{\am@gtot}{\textwidth-4mm}%
    \def\am@dotstart{\ifamdark white\else amNavy\fi}%
    % cabeçalho de meses + grade tracejada
    \foreach \am@m [count=\am@i from 0] in {#1} {
      \node[anchor=south, inner sep=0]
        at ({\am@glw+(\am@i+0.5)*\am@gcw pt},1.5mm)
        {\amcondlightfont\fontsize{5.6}{7}\selectfont\color{amGray}\am@m};
      \draw[amMist, dashed, line width=0.3pt]
        ({\am@glw+(\am@i+1)*\am@gcw pt},0) -- ({\am@glw+(\am@i+1)*\am@gcw pt},-\am@gh mm);
    }
    \draw[amGrayMid, line width=0.4pt] (0,0) -- (\am@gtot pt,0);
    % linhas de atividade
    \foreach \am@r/\am@a/\am@b [count=\am@j] in {#2} {
      \pgfmathsetmacro{\am@gy}{-(\am@j-0.5)*8}%
      \node[anchor=west, inner sep=0, text width={\am@glw-2mm}]
        at (0,\am@gy mm)
        {\amcondlightfont\fontsize{6.2}{7.5}\selectfont\color{\am@fg}\am@r};
      \fill[amSlate!35, rounded corners=1.4mm]
        ({\am@glw+(\am@a-1)*\am@gcw pt+1mm},\am@gy mm-1.4mm)
        rectangle ({\am@glw+\am@b*\am@gcw pt-1mm},\am@gy mm+1.4mm);
      \fill[\am@dotstart]
        ({\am@glw+(\am@a-1)*\am@gcw pt+2.4mm},\am@gy mm) circle (1mm);
      \fill[amSignal] ({\am@glw+\am@b*\am@gcw pt-2.4mm},\am@gy mm) circle (1mm);
      \draw[amMist, line width=0.3pt]
        (0,{\am@gy mm-4mm}) -- (\am@gtot pt,{\am@gy mm-4mm});
    }
  \end{tikzpicture}
  \end{center}
}


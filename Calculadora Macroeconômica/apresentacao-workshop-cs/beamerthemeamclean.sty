% beamerthemeamclean.sty
% Tema Beamer Alvarez & Marsal — derivado do template oficial
% "Template Alvarez And Marsal.potx" (master global A&M, 16:9).
% Requer XeLaTeX ou LuaLaTeX (fontspec + Arial Nova).
%
% Geometria de referência: slide PPT 33.87 x 19.05 cm -> beamer 160 x 90 mm
% (fator 0.4724 aplicado a todas as posições e corpos de texto).

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{beamerthemeamclean}[2026/06/10 v1.5 A&M Clean Beamer theme]

\mode<presentation>

% -------------------------------------------------%
% Pacotes
% -------------------------------------------------%
\RequirePackage{fontspec}
\RequirePackage{tikz}
\RequirePackage{xcolor}
\RequirePackage{etoolbox}
\RequirePackage{kvoptions}
\RequirePackage[skins]{tcolorbox}
\usetikzlibrary{calc}

% -------------------------------------------------%
% Opções do tema
% -------------------------------------------------%
\SetupKeyvalOptions{family=amclean,prefix=amclean@}
\DeclareStringOption[.]{assets}[.]
\ProcessKeyvalOptions*

\newcommand{\am@assets}{\amclean@assets}

% Inclui imagem cobrindo a área WxH sem distorcer (excedente é clipado pelo caller)
\newcommand{\am@fitimg}[3]{%
  \setbox\@tempboxa=\hbox{\includegraphics[height=#3]{#1}}%
  \ifdim\wd\@tempboxa<#2
    \includegraphics[width=#2]{#1}%
  \else
    \box\@tempboxa
  \fi}

% -------------------------------------------------%
% Cores oficiais A&M (DESIGN.md / potx)
% -------------------------------------------------%
\definecolor{amNavy}{HTML}{002B49}      % Midnight Marine - primária
\definecolor{amSlate}{HTML}{5E8AB4}     % Slate Blue - secundária
\definecolor{amSignal}{HTML}{0085CA}    % Signal Blue - destaque digital
\definecolor{amSlateLight}{HTML}{9EB9D2}% Slate claro (eyebrow em slide dark)
\definecolor{amGray}{HTML}{646464}      % Graphite - corpo de apoio
\definecolor{amGrayMid}{HTML}{969696}
\definecolor{amGrayFoot}{HTML}{7F7F7F}  % rodapé / fonte das informações
\definecolor{amMist}{HTML}{D9D9D9}      % superfícies suaves / divisores
\definecolor{amBackNavy}{HTML}{091B34}  % fundo da contracapa
% Acentos (usar no máximo UM por apresentação)
\definecolor{amTeal}{HTML}{00677F}
\definecolor{amOrange}{HTML}{CF7F00}
\definecolor{amMagenta}{HTML}{C8187D}
\definecolor{amPurple}{HTML}{722282}
\definecolor{amOlive}{HTML}{789904}
\definecolor{amRed}{HTML}{A6192E}
\definecolor{amYellow}{HTML}{F9C20A}
\definecolor{amGreen}{HTML}{29702A}
% Cores de gráficos (exemplos oficiais de Charts do Template.pptx)
\definecolor{amGold}{HTML}{CE8E00}
\definecolor{amMint}{HTML}{50D8B4}
\definecolor{amGreenDark}{HTML}{02624B}
\definecolor{amOrangeVivid}{HTML}{FF6D00}

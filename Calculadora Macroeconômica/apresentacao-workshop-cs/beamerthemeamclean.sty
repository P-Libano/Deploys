% -------------------------------------------------%
% Componentes de conteúdo
% -------------------------------------------------%
% Caixa de destaque (número/insight) — estilo "Caixa de destaque" do potx
\newcommand{\amhighlight}[2]{%
  {\amcondfont\bfseries\fontsize{12}{13.5}\selectfont\color{amSignal}#1\par}%
  {\vspace*{0.4mm}\amcondlightfont\fontsize{6.2}{8}\selectfont\color{\am@fg}#2\par}%
}

% Stat: número grande + rótulo (respiro extra após o rótulo para empilhar)
\newcommand{\amstat}[2]{%
  \begin{minipage}[t]{\linewidth}
    {\amcondfont\bfseries\fontsize{14}{15}\selectfont\color{amSignal}#1\par}
    {\vspace*{0.7mm}\amcondlightfont\fontsize{5.6}{7}\selectfont\color{amGray}#2\par}
    \vspace*{2.2mm}
  \end{minipage}%
}

% Timeline horizontal — \amtimeline{Rótulo 1/Texto um, Rótulo 2/Texto dois, ...}
% Separador de itens: vírgula. Separador rótulo/texto: barra.
% Evitar vírgulas dentro dos itens (ou proteger o item com chaves).
\newcommand{\amtimeline}[1]{%
  \begin{center}
  \begin{tikzpicture}
    \foreach \am@lbl/\am@txt [count=\am@i] in {#1} {\global\let\am@n=\am@i}
    \pgfmathsetmacro{\am@colw}{0.9*\textwidth/\am@n}%
    \pgfmathsetmacro{\am@step}{\am@n>1 ? (\textwidth-\am@colw)/(\am@n-1) : 1}%
    \draw[amSlate, line width=0.6pt] (0,0) -- (\am@n*\am@step pt-\am@step pt,0);
    \foreach \am@lbl/\am@txt [count=\am@i from 0] in {#1} {
      \fill[amSignal] (\am@i*\am@step pt,0) circle (1.1mm);
      \node[anchor=south, inner sep=0, yshift=2.2mm,
            text width=\am@colw pt, align=center]
        at (\am@i*\am@step pt,0)
        {\amcondnhfont\bfseries\fontsize{6.5}{8}\selectfont\color{\am@fg}\am@lbl};
      \node[anchor=north, inner sep=0, yshift=-2.2mm,
            text width=\am@colw pt, align=center]
        at (\am@i*\am@step pt,0)
        {\amcondlightnhfont\fontsize{5.6}{7.2}\selectfont\color{\ifamdark amMist\else amGray\fi}\am@txt};
    }
  \end{tikzpicture}
  \end{center}
}

% Card flat com borda 0.5pt (sem sombra, conforme brand guide)
\newenvironment{amcard}{%
  \begin{tcolorbox}[enhanced, sharp corners, boxrule=0.5pt,
    colframe=amMist, colback=white, left=2.4mm, right=2.4mm,
    top=2.2mm, bottom=2.2mm, boxsep=0pt]%
    \setbeamercolor{normal text}{fg=amNavy}%
    \setbeamercolor{itemize/enumerate body}{fg=amNavy}%
    \usebeamercolor[fg]{normal text}\color{amNavy}%
}{\end{tcolorbox}}


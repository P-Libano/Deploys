\definecolor{amRedVivid}{HTML}{BC0404}
\definecolor{amTableStripe}{HTML}{DCE6F1}

% -------------------------------------------------%
% Fontes — Arial Nova (oficial da marca)
% -------------------------------------------------%
% Padrão da casa: Arial Nova Light para todo o texto;
% bold (ênfase) usa Arial Nova Bold; textos pequenos usam Cond Light.
\setsansfont{ArialNova-Light}[
  Path            = \am@assets/fonts/,
  Extension       = .ttf,
  Ligatures       = TeX,
  BoldFont        = ArialNova-Bold,
  ItalicFont      = ArialNova-LightItalic,
  BoldItalicFont  = ArialNova-BoldItalic,
]
\newfontfamily\amlightfont{ArialNova-Light}[
  Path=\am@assets/fonts/, Extension=.ttf, Ligatures=TeX,
  BoldFont=ArialNova, ItalicFont=ArialNova-LightItalic]
\newfontfamily\amcondfont{ArialNovaCond}[
  Path=\am@assets/fonts/, Extension=.ttf, Ligatures=TeX,
  BoldFont=ArialNovaCond-Bold, ItalicFont=ArialNovaCond-Italic]
\newfontfamily\amcondlightfont{ArialNovaCond-Light}[
  Path=\am@assets/fonts/, Extension=.ttf, Ligatures=TeX,
  BoldFont=ArialNovaCond, ItalicFont=ArialNovaCond-LightItalic]
% Variantes sem hifenização (títulos de capa/separador e rótulos de componentes)
\newfontfamily\amlightnhfont{ArialNova-Light}[
  Path=\am@assets/fonts/, Extension=.ttf, Ligatures=TeX, HyphenChar=None,
  BoldFont=ArialNova-Bold]
\newfontfamily\amcondnhfont{ArialNovaCond}[
  Path=\am@assets/fonts/, Extension=.ttf, Ligatures=TeX, HyphenChar=None,
  BoldFont=ArialNovaCond-Bold]
\newfontfamily\amcondlightnhfont{ArialNovaCond-Light}[
  Path=\am@assets/fonts/, Extension=.ttf, Ligatures=TeX, HyphenChar=None,
  BoldFont=ArialNovaCond]
\renewcommand{\familydefault}{\sfdefault}

% -------------------------------------------------%
% Modo claro / escuro por frame
% -------------------------------------------------%
\newif\ifamdark
\amdarkfalse

\newcommand{\am@fg}{\ifamdark white\else amNavy\fi}
\newcommand{\am@eyebrowcolor}{\ifamdark amSlateLight\else amSlate\fi}
\newcommand{\am@logo}{\ifamdark \am@assets/logos/am-wordmark-white.png\else \am@assets/logos/am-wordmark-navy.png\fi}

% Ambiente para sequência de frames escuros: \begin{amdark} <frames> \end{amdark}
\newenvironment{amdark}{%
  \amdarktrue
  \setbeamercolor{background canvas}{bg=amNavy}%
  \setbeamercolor{normal text}{fg=white}%
  \setbeamercolor{itemize item}{fg=amSlateLight}%
  \setbeamercolor{itemize subitem}{fg=amSlateLight}%
  \setbeamercolor{enumerate item}{fg=amSlateLight}%
  \usebeamercolor[fg]{normal text}%
}{%
  \amdarkfalse
}

% -------------------------------------------------%
% Cores beamer
% -------------------------------------------------%
\setbeamercolor{background canvas}{bg=white}
\setbeamercolor{normal text}{fg=amNavy}
\setbeamercolor{structure}{fg=amNavy}
\setbeamercolor{frametitle}{fg=amNavy}
\setbeamercolor{itemize item}{fg=amSlate}
\setbeamercolor{itemize subitem}{fg=amSlate}
\setbeamercolor{itemize subsubitem}{fg=amSlate}
\setbeamercolor{enumerate item}{fg=amSlate}
\setbeamercolor{caption name}{fg=amGray}
\setbeamercolor{block title}{fg=white,bg=amNavy}
\setbeamercolor{block body}{fg=amNavy,bg=amMist!40}
\setbeamercolor{alerted text}{fg=amSignal}
\setbeamercolor{footnote}{fg=amGrayFoot}
\setbeamercolor{footnote mark}{fg=amGrayFoot}

% -------------------------------------------------%
% Tipografia (corpos fiéis ao potx, fator 0.4724)
% -------------------------------------------------%
\setbeamerfont{frametitle}{size={\fontsize{12.5}{14.5}}}
\setbeamerfont{normal text}{size={\fontsize{7}{9.2}}}
\setbeamerfont{itemize/enumerate body}{size={\fontsize{7}{9.2}}}
\setbeamerfont{itemize/enumerate subbody}{size={\fontsize{6.2}{8.2}}}
\setbeamerfont{itemize/enumerate subsubbody}{size={\fontsize{5.6}{7.4}}}
\setbeamerfont{caption}{size={\fontsize{5}{6.5}}}
\setbeamerfont{block title}{size={\fontsize{7.5}{9.5}},series=\bfseries}

\AtBeginDocument{\fontsize{7}{9.2}\selectfont}

% Marcadores: bullet simples (regramento oficial; nunca traço ou travessão)
\setbeamertemplate{itemize item}{\textbullet}
\setbeamertemplate{itemize subitem}{\raisebox{0.18ex}{\scriptsize\textbullet}}
\setbeamertemplate{itemize subsubitem}{\raisebox{0.22ex}{\tiny\textbullet}}
\setbeamertemplate{caption}{\amcondlightfont\insertcaption}
\setbeamertemplate{navigation symbols}{}
\setbeamertemplate{blocks}[rounded=false]

\setbeamersize{text margin left=3.2mm, text margin right=3.2mm}

% -------------------------------------------------%
% Dados extras da capa
% -------------------------------------------------%
\newcommand{\am@client}{}
\newcommand{\client}[1]{\renewcommand{\am@client}{#1}}
\newcommand{\am@coverimg}{\am@assets/covers/cover-light.jpg}
\newcommand{\coverimage}[1]{\renewcommand{\am@coverimg}{#1}}
\newcommand{\am@coverimgdark}{\am@assets/covers/cover-dark.jpg}
\newcommand{\coverimagedark}[1]{\renewcommand{\am@coverimgdark}{#1}}
% Rótulo de confidencialidade opcional (canto superior direito da capa)
\newcommand{\am@confidencial}{}
\newcommand{\confidencial}[1]{\renewcommand{\am@confidencial}{#1}}
% Nível de classificação no rodapé de todos os slides de conteúdo (regramento)
\newcommand{\am@classification}{}
\newcommand{\amclassification}[1]{\renewcommand{\am@classification}{#1}}

% -------------------------------------------------%
% Take away e Fonte das informações (por frame)
% -------------------------------------------------%
\newcommand{\am@takeaway}{}
\newcommand{\takeaway}[1]{\gdef\am@takeaway{#1}}
\newcommand{\am@fonte}{}
\newcommand{\fonte}[1]{\gdef\am@fonte{#1}}

% -------------------------------------------------%
% Cabeçalho dos frames de conteúdo
%   eyebrow (seção)  +  régua slate  +  wordmark  +  título
% -------------------------------------------------%
\defbeamertemplate*{frametitle}{amclean}{}

\newcommand{\am@chrome}{%
  \begin{tikzpicture}[remember picture, overlay]
    % régua superior em toda a largura (y = 4.72mm)
    \draw[\am@eyebrowcolor, line width=0.5pt]
      (current page.north west) ++(0,-4.72mm) -- ++(\paperwidth,0);
    % eyebrow: seção corrente, caixa alta, Arial Nova Cond, tracking leve
    \node[anchor=west, inner sep=0] at ($(current page.north west)+(3.2mm,-2.4mm)$)
      {\amcondlightfont\addfontfeature{LetterSpace=6}\fontsize{5.2}{6}\selectfont
       \color{\am@eyebrowcolor}\MakeUppercase{\insertsection}};
    % wordmark A&M no canto superior direito
    \node[anchor=east, inner sep=0] at ($(current page.north east)+(-3.2mm,-2.4mm)$)
      {\includegraphics[width=14.3mm]{\am@logo}};
  \end{tikzpicture}%
}

\newcommand{\am@pagenum}{%
  \begin{tikzpicture}[remember picture, overlay]
    \node[anchor=south east, inner sep=0]
      at ($(current page.south east)+(-3.2mm,1.5mm)$)
      {\amcondlightfont\fontsize{4.5}{5.5}\selectfont\color{amGrayFoot}\insertframenumber};
  \end{tikzpicture}%
}

% headline desenha o chrome em todo frame de conteúdo
\setbeamertemplate{headline}{%
  \ifnum\insertframenumber>0\am@chrome\fi
  \vspace*{5.2mm}%
}

% título do frame
\setbeamertemplate{frametitle}{%
  \vspace*{1.2mm}%
  {\amlightfont\fontsize{12.5}{14}\selectfont\color{\am@fg}\insertframetitle\par}%
  \ifx\insertframesubtitle\@empty\else
    {\vspace*{0.6mm}\fontsize{7.5}{9}\selectfont\color{\am@fg}\insertframesubtitle\par}%
  \fi
  \vspace*{1.6mm}%
}

% rodapé: take away + fonte + número
\setbeamertemplate{footline}{%
  \ifx\am@takeaway\@empty\else
    \begin{tikzpicture}[remember picture, overlay]
      \node[anchor=south west, inner sep=0, text width=\dimexpr\paperwidth-30mm\relax]
        at ($(current page.south west)+(3.2mm,5.8mm)$)
        {\amcondfont\bfseries\fontsize{7.5}{9}\selectfont
         \color{\am@fg}\am@takeaway};
    \end{tikzpicture}%
    \gdef\am@takeaway{}%
  \fi
  \ifx\am@fonte\@empty\else
    \begin{tikzpicture}[remember picture, overlay]
      \node[anchor=south west, inner sep=0]
        at ($(current page.south west)+(3.2mm,1.5mm)$)
        {\amcondlightfont\fontsize{4.5}{5.5}\selectfont\color{amGrayFoot}Fonte: \am@fonte};
    \end{tikzpicture}%
    \gdef\am@fonte{}%
  \fi
  \ifx\am@classification\@empty\else
    \begin{tikzpicture}[remember picture, overlay]
      \node[anchor=south, inner sep=0] at ($(current page.south)+(0,1.5mm)$)
        {\amcondlightfont\fontsize{4.5}{5.5}\selectfont\color{amGrayFoot}\MakeUppercase{\am@classification}};
    \end{tikzpicture}%
  \fi
  \am@pagenum
}

% -------------------------------------------------%
% CAPA  —  \amcover (escura, padrão da casa)  ou  \amcover[light]
% -------------------------------------------------%
\newcommand{\amcover}[1][dark]{%
  \begingroup
  \def\am@mode{#1}%
  \begin{frame}[plain, noframenumbering]
    \begin{tikzpicture}[remember picture, overlay]
      \ifdefstring{\am@mode}{dark}{%
        \begin{scope}\clip (current page.north west) rectangle (current page.south east);
          \node[anchor=center, inner sep=0] at (current page.center)
            {\am@fitimg{\am@coverimgdark}{\paperwidth}{\paperheight}};
        \end{scope}%
        \def\am@coverfg{white}%
        \node[anchor=north west, inner sep=0] at ($(current page.north west)+(3.2mm,-4.9mm)$)
          {\includegraphics[width=46.9mm]{\am@assets/logos/am-infra-white.png}};
      }{%
        \begin{scope}\clip (current page.north west) rectangle (current page.south east);
          \node[anchor=center, inner sep=0] at (current page.center)
            {\am@fitimg{\am@coverimg}{\paperwidth}{\paperheight}};
        \end{scope}%
        \def\am@coverfg{amNavy}%
        \node[anchor=north west, inner sep=0] at ($(current page.north west)+(3.2mm,-4.9mm)$)
          {\includegraphics[width=46.9mm]{\am@assets/logos/am-infra-color.png}};
      }%
      % Três réguas da capa, começando alinhadas com o texto (x=3.2mm) e
      % terminando junto com o fim da data (x=paperwidth-3.2mm).
      % Respiros: 50% do corpo do título (19pt -> 3.3mm) ao redor do título;
      % 50% do corpo do subtítulo (7.5pt -> 1.3mm) ao redor do subtítulo.
      \draw[\am@coverfg, line width=0.4pt]
        ($(current page.north west)+(3.2mm,-67.4mm)$) -- ($(current page.north east)+(-3.2mm,-67.4mm)$);
      \draw[\am@coverfg, line width=0.4pt]
        ($(current page.north west)+(3.2mm,-80.7mm)$) -- ($(current page.north east)+(-3.2mm,-80.7mm)$);
      \draw[\am@coverfg, line width=0.4pt]
        ($(current page.north west)+(3.2mm,-86.1mm)$) -- ($(current page.north east)+(-3.2mm,-86.1mm)$);
      % Título grande (40pt PPT -> 19pt, Arial Nova Light): cliente, ou o título
      % da apresentação quando \client não for definido
      \node[anchor=north west, inner sep=0, text width=153mm]
        at ($(current page.north west)+(3.2mm,-70.7mm)$)
        {\amlightnhfont\fontsize{19}{21}\selectfont\color{\am@coverfg}%
         \ifdefempty{\am@client}{\inserttitle}{\am@client}};
      % Linha do subtítulo (16pt PPT -> 7.5pt, Arial Nova Light)
      \node[anchor=north west, inner sep=0, text width=102mm]
        at ($(current page.north west)+(3.2mm,-82.1mm)$)
        {\amlightfont\fontsize{7.5}{9}\selectfont\color{\am@coverfg}%
         \ifdefempty{\am@client}{\insertsubtitle}{\inserttitle}};
      % Data (alinhada à direita, Arial Nova Light)
      \node[anchor=north east, inner sep=0]
        at ($(current page.north east)+(-3.2mm,-82.1mm)$)
        {\amlightfont\fontsize{7.5}{9}\selectfont\color{\am@coverfg}\insertdate};
      % Rótulo de confidencialidade (opcional, canto superior direito)
      \ifx\am@confidencial\@empty\else
        \node[anchor=north east, inner sep=0]
          at ($(current page.north east)+(-3.2mm,-5.2mm)$)
          {\amlightfont\addfontfeature{LetterSpace=6}\fontsize{5.5}{6.5}\selectfont
           \color{\am@coverfg}\MakeUppercase{\am@confidencial}};
      \fi
    \end{tikzpicture}%
  \end{frame}
  \endgroup
}

% -------------------------------------------------%
% CAPA CORPORATIVA V2 — \amcovercorp[dark|light]{foto-direita}
% Layout "Cover Static" do template Apresentação Institucional_V2:
% banda vertical com o grafismo A&M à esquerda (logo, data, título,
% confidencialidade) e foto full-height à direita.
% Fotos do catálogo: covers/cidade-ruas.jpg, energia.jpg, global.jpg,
% tecnologia.jpg, america-sul.jpg, cover-dark.jpg, cover-light.jpg...
% -------------------------------------------------%
\NewDocumentCommand{\amcovercorp}{O{dark} m}{%
  \begingroup
  \def\am@mode{#1}%
  \begin{frame}[plain, noframenumbering]
    \begin{tikzpicture}[remember picture, overlay]
      % foto à direita (de x=55.7mm até a borda, altura cheia, com clip)
      \begin{scope}
        \clip ($(current page.north west)+(55.7mm,0)$) rectangle (current page.south east);
        \node[anchor=center, inner sep=0]
          at ($(current page.east)+(-52.15mm,0)$)
          {\am@fitimg{#2}{104.3mm}{\paperheight}};
      \end{scope}
      % banda com grafismo A (48.7mm, altura cheia)
      \ifdefstring{\am@mode}{dark}{%
        \node[anchor=north west, inner sep=0] at (current page.north west)
          {\includegraphics[width=48.7mm, height=\paperheight]{\am@assets/covers/banda-dark.jpg}};
        \def\am@ccfg{white}%
        \node[anchor=north west, inner sep=0] at ($(current page.north west)+(4mm,-4.9mm)$)
          {\includegraphics[width=30mm]{\am@assets/logos/am-infra-white.png}};
      }{%
        \node[anchor=north west, inner sep=0] at (current page.north west)
          {\includegraphics[width=48.7mm, height=\paperheight]{\am@assets/covers/banda-light.jpg}};
        \def\am@ccfg{amNavy}%
        \node[anchor=north west, inner sep=0] at ($(current page.north west)+(4mm,-4.9mm)$)
          {\includegraphics[width=30mm]{\am@assets/logos/am-infra-color.png}};
      }%
      % cliente (opcional), data e título, todos em Arial Nova Light
      \ifdefempty{\am@client}{}{%
        \node[anchor=north west, inner sep=0, text width=40mm]
          at ($(current page.north west)+(4.5mm,-37mm)$)
          {\amlightfont\fontsize{8}{10}\selectfont\color{\am@ccfg}\am@client};
      }%
      \node[anchor=north west, inner sep=0]
        at ($(current page.north west)+(4.5mm,-42.3mm)$)
        {\amlightfont\addfontfeature{LetterSpace=6}\fontsize{6}{7}\selectfont
         \color{\am@ccfg}\MakeUppercase{\insertdate}};
      \node[anchor=north west, inner sep=0, text width=41mm, align=left]
        at ($(current page.north west)+(4.5mm,-45.8mm)$)
        {\amlightnhfont\fontsize{15}{17.5}\selectfont\color{\am@ccfg}\inserttitle};
      % confidencialidade na base da banda
      \ifx\am@confidencial\@empty\else
        \node[anchor=south west, inner sep=0]
          at ($(current page.south west)+(4.5mm,3.5mm)$)
          {\amlightfont\addfontfeature{LetterSpace=6}\fontsize{4}{5}\selectfont
           \color{\am@ccfg}\MakeUppercase{\am@confidencial}};
      \fi
    \end{tikzpicture}%
  \end{frame}
  \endgroup
}

% -------------------------------------------------%
% SEPARADOR DE SEÇÃO
%   \amsection{Título}                separador claro
%   \amsection[dark]{Título}          separador navy
%   \amsection[dark]{Título}[foto]    com foto na metade direita
% Cria a \section, numera o capítulo automaticamente (01, 02, ...)
% e desenha o frame divisor no estilo "Section break" do potx.
% -------------------------------------------------%
\newcounter{amchapter}
\NewDocumentCommand{\amsection}{O{light} m o}{%
  \section{#2}%
  \stepcounter{amchapter}%
  \begingroup
  \def\am@mode{#1}%
  \begin{frame}[plain, noframenumbering]
    \begin{tikzpicture}[remember picture, overlay]
      \ifdefstring{\am@mode}{dark}{%
        \fill[amNavy] (current page.north west) rectangle (current page.south east);
        \def\am@sbfg{white}\def\am@sblogo{\am@assets/logos/am-wordmark-white.png}%
        \def\am@sbeyebrow{amSlateLight}%
      }{%
        \def\am@sbfg{amNavy}\def\am@sblogo{\am@assets/logos/am-wordmark-navy.png}%
        \def\am@sbeyebrow{amSlate}%
      }%
      % foto opcional ocupando a metade direita (full-bleed, com clip)
      \IfValueT{#3}{%
        \begin{scope}
          \clip ($(current page.north west)+(0.55\paperwidth,0)$)
            rectangle (current page.south east);
          \node[anchor=east, inner sep=0] at (current page.east)
            {\includegraphics[height=\paperheight]{#3}};
        \end{scope}%
      }%
      \draw[\am@sbeyebrow, line width=0.5pt]
        (current page.north west) ++(0,-4.72mm) -- ++(\paperwidth,0);
      \node[anchor=east, inner sep=0] at ($(current page.north east)+(-3.2mm,-2.4mm)$)
        {\includegraphics[width=14.3mm]{\am@sblogo}};
      % Número do capítulo (01, 02, ...) acima do título
      \node[anchor=north west, inner sep=0]
        at ($(current page.north west)+(3.2mm,-29mm)$)
        {\amlightfont\fontsize{26}{28}\selectfont
         \color{\am@sbeyebrow}\two@digits{\value{amchapter}}};
      % Título grande (40pt potx -> 19pt) a meia altura, sem hifenização
      \node[anchor=north west, inner sep=0,
            text width=\IfValueTF{#3}{80mm}{140mm}]
        at ($(current page.north west)+(3.2mm,-43mm)$)
        {\amlightnhfont\raggedright\fontsize{19}{22}\selectfont\color{\am@sbfg}#2};
    \end{tikzpicture}%
  \end{frame}
  \endgroup
}

